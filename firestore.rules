rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ==================== SHOPS COLLECTION ====================
    // Shop documents only — no subcollections needed
    // All POS data (menu, transactions, settings) is stored in localStorage

    match /shops/{shopId} {
      // Admin can list/query shops (for activation code lookup, dashboard)
      allow list: if isAdmin();

      // Shop owner can read their own doc, admin can read all
      allow read: if isAuthenticated() && (isOwner(shopId) || isAdmin());

      // Shop owner can create their own doc (only with 'pending' status on registration)
      allow create: if isAuthenticated() && isOwner(shopId) && request.resource.data.status == 'pending';

      // Only admin can update shop docs (activate, demo, reject, disable, etc.)
      allow update: if isAdmin();
    }

    // ==================== DEMO CODES COLLECTION ====================
    // Demo codes for trial access (DEMO-XXXXXX)
    // Codes expire 7 days after creation, trial is 24 hours

    match /demoCodes/{codeId} {
      // Admin can list/query demo codes
      allow list: if isAdmin();

      // Admin can read all demo codes
      allow read: if isAdmin();

      // Only admin can create demo codes
      allow create: if isAdmin();

      // Authenticated users can update (to mark code as used when redeeming)
      allow update: if isAuthenticated();

      // Only admin can delete demo codes
      allow delete: if isAdmin();
    }

    // ==================== ADMINS COLLECTION ====================

    match /admins/{adminId} {
      allow read: if isAuthenticated() && isOwner(adminId);
      allow create: if false; // Only create via Firebase Console
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ==================== ACTIVITY LOG ====================

    match /activityLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
